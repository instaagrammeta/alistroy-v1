# =========================================================
# AliStroy backend (Go) — multi-stage build
# =========================================================

FROM golang:1.22-alpine AS builder
WORKDIR /src

RUN apk add --no-cache ca-certificates git tzdata

# Pre-cache modules (go.sum is generated by go mod tidy below if absent)
COPY go.mod go.sum* ./
RUN go mod download || true

COPY . .
RUN go mod tidy

ENV CGO_ENABLED=0 GOOS=linux GOARCH=amd64
RUN go build -ldflags="-s -w" -o /out/alistroy ./cmd/api

# ---- runtime ----
FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata wget && \
    addgroup -S app && adduser -S app -G app

WORKDIR /app
COPY --from=builder /out/alistroy /app/alistroy
RUN mkdir -p /app/uploads && chown -R app:app /app

ENV API_HOST=0.0.0.0 API_PORT=8080 API_ENV=production
EXPOSE 8080
USER app

HEALTHCHECK --interval=15s --timeout=5s --start-period=20s --retries=5 \
    CMD wget -q -O - http://localhost:8080/health || exit 1

CMD ["/app/alistroy"]
