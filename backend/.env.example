# =========================================================
# AliStroy v2 backend — local example
# =========================================================
API_PORT=8080
API_HOST=0.0.0.0
API_ENV=development
API_LOG_LEVEL=debug

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=alistroy
POSTGRES_PASSWORD=alistroy
POSTGRES_DB=alistroy
POSTGRES_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=dev_secret_change_me_to_a_long_random_string_minimum_32_chars
JWT_ACCESS_TTL_MINUTES=120
JWT_REFRESH_TTL_HOURS=720

# Uploads
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=50
UPLOAD_PUBLIC_BASE=/uploads

# CORS / rate
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_RPS=30
RATE_LIMIT_BURST=60

# Marketplace defaults (used when contact_owner=admin)
MARKETPLACE_PHONE=+992000000000
MARKETPLACE_WHATSAPP=+992000000000
MARKETPLACE_TELEGRAM=+992000000000
MARKETPLACE_TELEGRAM_USERNAME=@alistroy

# Bootstrap admin
ADMIN_EMAIL=admin@alistroy.tj
ADMIN_PHONE=+992900000000
ADMIN_PASSWORD=ChangeMe_StrongPass1!
ADMIN_NAME=AliStroy Admin

# Public site URL
PUBLIC_URL=http://localhost:3000

# Google OAuth (optional — disable by leaving empty)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:3000/auth/google/callback
