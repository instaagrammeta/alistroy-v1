# =========================================================
# AliStroy environment configuration
# Copy this file to .env and fill in real values for prod.
# =========================================================

# --- Public domain ---
PUBLIC_DOMAIN=alistroy.tj
PUBLIC_URL=https://alistroy.tj

# --- PostgreSQL ---
POSTGRES_USER=alistroy
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=alistroy
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Backend (Go API) ---
API_PORT=8080
API_HOST=0.0.0.0
API_ENV=production
API_LOG_LEVEL=info

JWT_SECRET=please_change_me_to_a_long_random_secret_string_min_32_chars
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_HOURS=720

UPLOAD_DIR=/app/uploads
UPLOAD_MAX_SIZE_MB=10
UPLOAD_PUBLIC_BASE=/uploads

CORS_ALLOWED_ORIGINS=https://alistroy.tj,http://localhost:3000

RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40

# --- Marketplace default contacts (used when a product
#     uses contact_type=admin) ---
MARKETPLACE_PHONE=+992000000000
MARKETPLACE_WHATSAPP=+992000000000

# --- Bootstrap admin account (created on first boot) ---
ADMIN_EMAIL=admin@alistroy.tj
ADMIN_PASSWORD=ChangeMe_StrongPass1!
ADMIN_NAME=AliStroy Admin

# --- Frontend (Nuxt) ---
NUXT_PORT=3000
NUXT_HOST=0.0.0.0
NUXT_PUBLIC_API_BASE=/api/v1
NUXT_PUBLIC_SITE_URL=https://alistroy.tj
NUXT_PUBLIC_UPLOADS_BASE=/uploads
NUXT_PUBLIC_DEFAULT_LOCALE=tg

# --- Nginx ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
