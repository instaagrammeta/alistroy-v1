# =========================================================
# AliStroy v2 — root environment (used by docker-compose)
# Copy to .env and edit before `docker compose up -d --build`.
# =========================================================

# --- Public domain / URL ---
PUBLIC_URL=https://alistroy.tj

# --- PostgreSQL ---
POSTGRES_USER=alistroy
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=alistroy
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Backend API ---
API_PORT=8080
API_HOST=0.0.0.0
API_ENV=production
API_LOG_LEVEL=info

JWT_SECRET=please_change_me_to_a_long_random_secret_min_32_chars
JWT_ACCESS_TTL_MINUTES=120
JWT_REFRESH_TTL_HOURS=720

UPLOAD_DIR=/app/uploads
UPLOAD_MAX_SIZE_MB=50
UPLOAD_PUBLIC_BASE=/uploads

CORS_ALLOWED_ORIGINS=https://alistroy.tj,http://localhost:3000
RATE_LIMIT_RPS=30
RATE_LIMIT_BURST=60

# --- Marketplace default contacts (contact_owner=admin) ---
MARKETPLACE_PHONE=+992000000000
MARKETPLACE_WHATSAPP=+992000000000
MARKETPLACE_TELEGRAM=+992000000000
MARKETPLACE_TELEGRAM_USERNAME=@alistroy

# --- Bootstrap admin (created on first boot) ---
ADMIN_EMAIL=admin@alistroy.tj
ADMIN_PHONE=+992900000000
ADMIN_PASSWORD=ChangeMe_StrongPass1!
ADMIN_NAME=AliStroy Admin

# --- Google OAuth (optional; leave empty to disable) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=https://alistroy.tj/auth/google/callback

# --- Nginx ---
NGINX_HTTP_PORT=80

# --- Frontend (Nuxt) ---
NUXT_PUBLIC_API_BASE=/api/v1
NUXT_PUBLIC_SITE_URL=https://alistroy.tj
NUXT_PUBLIC_UPLOADS_BASE=/uploads
NUXT_PUBLIC_DEFAULT_LOCALE=tg
